{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VaultMLN",
  "version": "2.0.0",
  "identifier": "com.wtrmln.vaultmln",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VaultMLN",
        "width": 980,
        "height": 740,
        "minWidth": 760,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../assets/VaultMLN-no-text.ico"
    ]
  }
}
